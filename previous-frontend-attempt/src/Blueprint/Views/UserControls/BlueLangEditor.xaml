<?xml version="1.0" encoding="UTF-8"?>
<UserControl x:Class="Blueprint.Views.UserControls.BlueLangEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Blueprint.Presentation.ViewModels.UserControls.Interfaces;assembly=Blueprint.Presentation.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:editor="http://schemas.actiprosoftware.com/winfx/xaml/syntaxeditor"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:services="clr-namespace:Blueprint.Services"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             DataContext="{services:Resolve Type={x:Type vm:IBlueLangEditorViewModel}}">
    <UserControl.Resources>
        <Style TargetType="{x:Type editor:IntelliPromptQuickInfo}"
               BasedOn="{StaticResource {x:Type editor:IntelliPromptQuickInfo}}">
            <Setter Property="Background" Value="{Binding BackgroundSolidBrush, Source={DynamicResource ApplicationBackgroundBrush}}" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <editor:SyntaxEditor x:Name="SyntaxEditor"
                             IsDefaultContextMenuEnabled="True"
                             ZoomLevel="1.3"
                             FontFamily="Cascadia Code"
                             Document="{Binding Document}"
                             IsCurrentLineHighlightingEnabled="True"
                             IsLineNumberMarginVisible="True">
            <editor:SyntaxEditor.ContextMenu>
                <ContextMenu Name="DefaultContextMenu">
                    <MenuItem Header="Undo"
                              Command="editor:EditorCommands.Undo"
                              InputGestureText="Ctrl+Z" />
                    <MenuItem Header="Redo"
                              Command="editor:EditorCommands.Redo"
                              InputGestureText="Ctrl+Y" />
                    <Separator />
                    <MenuItem Header="Cu_t"
                              Command="editor:EditorCommands.CutToClipboard"
                              InputGestureText="Ctrl+X" />
                    <MenuItem Header="_Copy"
                              Command="editor:EditorCommands.CopyToClipboard"
                              InputGestureText="Ctrl+C" />
                    <MenuItem Header="_Paste"
                              Command="editor:EditorCommands.PasteFromClipboard"
                              InputGestureText="Ctrl+V" />
                    <MenuItem Header="_Delete"
                              Command="editor:EditorCommands.Delete" />
                    <Separator />
                    <MenuItem Header="Select _All"
                              Command="editor:EditorCommands.SelectAll"
                              InputGestureText="Ctrl+A" />
                </ContextMenu>
            </editor:SyntaxEditor.ContextMenu>
        </editor:SyntaxEditor>
    </Grid>
</UserControl>