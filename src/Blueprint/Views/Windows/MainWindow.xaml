<?xml version="1.0" encoding="UTF-8"?>
<ui:FluentWindow x:Class="Blueprint.Views.Windows.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:Blueprint.Views.Windows"
                 xmlns:services="clr-namespace:Blueprint.Services"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{Binding ApplicationTitle, Mode=OneWay}"
                 Width="1100"
                 Height="650"
                 xmlns:vm="clr-namespace:Blueprint.ViewModels.Windows"
                 DataContext="{services:Resolve Type={x:Type vm:MainWindowViewModel}}"
                 d:DesignHeight="450"
                 d:DesignWidth="800"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 ExtendsContentIntoTitleBar="True"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
                <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           Padding="30,0,30,10"
                           BreadcrumbBar="{Binding ElementName=BreadcrumbBar}"
                           FooterMenuItemsSource="{Binding FooterMenuItems, Mode=OneWay}"
                           FrameMargin="0"
                           IsBackButtonVisible="Visible"
                           IsPaneToggleVisible="True"
                           MenuItemsSource="{Binding MenuItems, Mode=OneWay}"
                           PaneDisplayMode="LeftFluent">
                    <ui:NavigationView.Header>
                        <ui:BreadcrumbBar x:Name="BreadcrumbBar"
                                  Margin="42,32,42,20" />
                    </ui:NavigationView.Header>
                    <ui:NavigationView.ContentOverlay>
                        <ui:SnackbarPresenter x:Name="SnackbarPresenter" />
                    </ui:NavigationView.ContentOverlay>
                </ui:NavigationView>
                <ui:TitleBar x:Name="TitleBar"
                     Title="{Binding ApplicationTitle}"
                     Grid.Row="0"
                     CloseWindowByDoubleClickOnIcon="True">
                    <ui:TitleBar.Icon>
                        <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcoDark.png" />
                    </ui:TitleBar.Icon>
                </ui:TitleBar>
    </Grid>
</ui:FluentWindow>