<?xml version="1.0" encoding="UTF-8" ?>
<UserControl x:Class="TearableTab.TearableTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True">
    <UserControl.Resources>
        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Background"
                    Value="{DynamicResource ApplicationBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Padding"
                    Value="14,8,14,6" />
            <Setter Property="MinHeight"
                    Value="40" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid x:Name="Root"
                              SnapsToDevicePixels="True"
                              Margin="0,2,0,0">
                            <Border x:Name="HeaderBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10,10,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <TextBlock x:Name="HeaderText"
                                               Text="{TemplateBinding Header}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{TemplateBinding Foreground}"
                                               HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    <!-- Selected underline (stays when active) -->
                                    <Border x:Name="SelectedUnderline"
                                            Height="2"
                                            Opacity="0"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Stretch"
                                            CornerRadius="3"
                                            Margin="0,0,0,-2"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleY="0.6" />
                                        </Border.RenderTransform>
                                    </Border>
                                    <!-- Hover underline (animated, subtle) -->
                                    <Border x:Name="HoverUnderline"
                                            Height="2"
                                            Opacity="0"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Stretch"
                                            CornerRadius="3"
                                            Margin="0,0,0,-2"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleY="0.6" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Covers the bottom border line when this tab is selected,
                                 making it appear to merge with the content panel below. -->
                            <Border x:Name="BottomCover"
                                    Height="2"
                                    Background="{TemplateBinding Background}"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch"
                                    Margin="1,0,1,0"
                                    Opacity="0" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverUnderline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.22" />
                                            <DoubleAnimation Storyboard.TargetName="HoverUnderline"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.6"
                                                             Duration="0:0:0.22" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverUnderline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.55"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="HoverUnderline"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.8"
                                                             Duration="0:0:0.18" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.55"
                                                             Duration="0:0:0.10" />
                                            <DoubleAnimation Storyboard.TargetName="HoverUnderline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.10" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected">
                                        <Storyboard>
                                            <!-- Sink back down to resting margin -->
                                            <ThicknessAnimation Storyboard.TargetName="Root"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="0,2,0,0"
                                                                Duration="0:0:0.15" />
                                            <!-- Reset caption color -->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HeaderText"
                                                                           Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <!-- Hide the bottom cover so the border reappears -->
                                            <DoubleAnimation Storyboard.TargetName="BottomCover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="SelectedUnderline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="SelectedUnderline"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.6"
                                                             Duration="0:0:0.18" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <!-- Raise the tab upward by shrinking its top margin -->
                                            <ThicknessAnimation Storyboard.TargetName="Root"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="0,0,0,0"
                                                                Duration="0:0:0.15" />
                                            <!-- Selected caption uses accent -->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HeaderText"
                                                                           Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0"
                                                                        Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <!-- Paint over the bottom border so the tab merges with content panel -->
                                            <DoubleAnimation Storyboard.TargetName="BottomCover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="SelectedUnderline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="SelectedUnderline"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1"
                                                             Duration="0:0:0.12" />
                                            <!-- Never show hover underline when selected -->
                                            <DoubleAnimation Storyboard.TargetName="HoverUnderline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.01" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <TabControl x:Name="MainTabControl"
                    AllowDrop="True" />
    </Grid>
</UserControl>
