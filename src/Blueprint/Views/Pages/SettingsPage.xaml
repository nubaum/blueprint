<?xml version="1.0" encoding="UTF-8"?>
<Page x:Class="Blueprint.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:helpers="clr-namespace:Blueprint.Helpers"
      xmlns:local="clr-namespace:Blueprint.Views.Pages"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:services="clr-namespace:Blueprint.Services"
      xmlns:abs="clr-namespace:Blueprint.Abstractions.Application.Workspace;assembly=Blueprint.Application"
      xmlns:vm="clr-namespace:Blueprint.Presentation.ViewModels.Pages.Interfaces;assembly=Blueprint.Presentation.ViewModels"
      Title="SettingsPage"
      DataContext="{services:Resolve Type={x:Type vm:ISettingsViewModel}}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False"
      mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="Medium"
                           Text="Personalization" />
                <TextBlock Margin="0,12,0,0"
                           Text="Theme" />
                <RadioButton Margin="0,12,0,0"
                             Command="{Binding ThemeStore.ChangeThemeCommand, Mode=OneWay}"
                             CommandParameter="{x:Static abs:BlueprintTheme.Light}"
                             Content="Light"
                             GroupName="themeSelect"
                             IsChecked="{Binding ThemeStore.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static abs:BlueprintTheme.Light}, Mode=OneWay}" />
                <RadioButton Margin="0,8,0,0"
                             Command="{Binding ThemeStore.ChangeThemeCommand, Mode=OneWay}"
                             CommandParameter="{x:Static abs:BlueprintTheme.Dark}"
                             Content="Dark"
                             GroupName="themeSelect"
                             IsChecked="{Binding ThemeStore.CurrentTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static abs:BlueprintTheme.Dark}, Mode=OneWay}" />
                <TextBlock Margin="0,24,0,0"
                           FontSize="20"
                           FontWeight="Medium"
                           Text="About Blueprint" />
                <TextBlock Margin="0,12,0,0"
                           Text="{Binding AppVersion, Mode=OneWay}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
