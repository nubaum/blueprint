    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
              Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Margin="0,0,0,10">
                <TextBlock FontSize="20"
                           FontWeight="Medium"
                           Text="Coding" />
                <TextBlock Opacity="0.8"
                           Margin="0,4,0,0"
                           Text="Tree on the left, tabs on the right. Resize or collapse sections as needed." />
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftColumn"
                                      Width="260"
                                      MinWidth="160" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition x:Name="RightColumn"
                                      Width="*"
                                      MinWidth="260" />
                </Grid.ColumnDefinitions>
                <DockPanel Grid.Column="0"
                           LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Padding="0,0,0,8" />
                    <Border Padding="10"
                            CornerRadius="8">
                        <TreeView>
                            <TreeViewItem Header="Workspace">
                                <TreeViewItem Header="src">
                                    <TreeViewItem Header="Blueprint.App" />
                                    <TreeViewItem Header="Blueprint.Domain" />
                                    <TreeViewItem Header="Blueprint.Application" />
                                    <TreeViewItem Header="Blueprint.Infrastructure" />
                                    <TreeViewItem Header="Blueprint.Presentation.Wpf" />
                                </TreeViewItem>
                                <TreeViewItem Header="docs">
                                    <TreeViewItem Header="architecture.md" />
                                    <TreeViewItem Header="readme-notes.md" />
                                </TreeViewItem>
                                <TreeViewItem Header="assets">
                                    <TreeViewItem Header="icons" />
                                    <TreeViewItem Header="themes" />
                                </TreeViewItem>
                            </TreeViewItem>
                            <TreeViewItem Header="Favorites">
                                <TreeViewItem Header="Current File" />
                                <TreeViewItem Header="Recent" />
                            </TreeViewItem>
                        </TreeView>
                    </Border>
                </DockPanel>
                <Grid Grid.Column="1"
                      Background="Transparent">
                    <primitives:Thumb x:Name="SplitThumb"
                                      Cursor="SizeWE"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      DragDelta="SplitThumb_OnDragDelta"
                                      DragStarted="SplitThumb_OnDragStarted"
                                      DragCompleted="SplitThumb_OnDragCompleted">
                        <primitives:Thumb.Template>
                            <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                                <Grid Background="Transparent">
                                    <Border x:Name="Handle"
                                            Width="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Stretch"
                                            Margin="0,6"
                                            CornerRadius="2"
                                            Opacity="0.2"
                                            Background="{DynamicResource TextFillColorPrimaryBrush}">
                                        <Border.Effect>
                                            <DropShadowEffect x:Name="Glow"
                                                              BlurRadius="12"
                                                              ShadowDepth="0"
                                                              Opacity="0" />
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="Handle"
                                                Property="Width"
                                                Value="4" />
                                        <Setter TargetName="Handle"
                                                Property="Opacity"
                                                Value="0.7" />
                                        <Setter TargetName="Handle"
                                                Property="Background"
                                                Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsDragging"
                                             Value="True">
                                        <Setter TargetName="Handle"
                                                Property="Width"
                                                Value="4" />
                                        <Setter TargetName="Handle"
                                                Property="Opacity"
                                                Value="1" />
                                        <Setter TargetName="Handle"
                                                Property="Background"
                                                Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </primitives:Thumb.Template>
                    </primitives:Thumb>
                </Grid>
                <Grid Grid.Column="2">
                    <controls:TearableTabControl x:Name="MainTabs" />
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>