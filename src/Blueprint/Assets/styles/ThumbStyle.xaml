<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:prim="clr-namespace:Blueprint.Views.UserControls.Primitives">
    <Style TargetType="{x:Type prim:GridSplitterThumb}">
        <Setter Property="Width"
                Value="14" />
        <Setter Property="Cursor"
                Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type prim:GridSplitterThumb}">
                    <Grid Background="Transparent">
                        <Border x:Name="Handle"
                                Width="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Margin="0,6"
                                CornerRadius="2"
                                Opacity="0.2"
                                Background="{DynamicResource TextFillColorPrimaryBrush}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="Glow"
                                                  BlurRadius="12"
                                                  ShadowDepth="0"
                                                  Opacity="0" />
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter TargetName="Handle"
                                    Property="Width"
                                    Value="4" />
                            <Setter TargetName="Handle"
                                    Property="Opacity"
                                    Value="0.7" />
                            <Setter TargetName="Handle"
                                    Property="Background"
                                    Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging"
                                 Value="True">
                            <Setter TargetName="Handle"
                                    Property="Width"
                                    Value="4" />
                            <Setter TargetName="Handle"
                                    Property="Opacity"
                                    Value="1" />
                            <Setter TargetName="Handle"
                                    Property="Background"
                                    Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>